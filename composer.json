{
    "name": "yidianzhishi/learning",
    "type": "framework",
    "description": "一点知识学习平台",
    "version": "1.0.0",
    "homepage": "http://www.yidianzhishi.cn",
    "license": "",
    "authors": [
        {
            "name": "Li Guanghui",
            "email": "liguanghui2006@163.com"
        }
    ],
    "require": {
        "php": ">=7.0",
        "ext-curl": "*",
        "ext-gd": "*",
        "ext-mbstring": "*",
        "ext-mcrypt": "*",
        "ext-openssl": "*",
        "ext-pdo_mysql": "*",
        "ext-mongodb": "*",
        "ext-redis": "*",
        "ext-zip": "*",
        "ext-sockets": "*",
        "psr/http-message": "~1.0",
        "pimple/pimple": "~3.0",
        "apache/log4php": "2.3.0",
        "phpoffice/phpexcel": ">=1.8.0",
        "royfj/captcha": "0.1.0",
        "aliyuncs/oss-sdk-php": "^2.3",
        "rybakit/msgpack": "^0.2.2",
        "php-ffmpeg/php-ffmpeg": "^0.9.3",
        "royfj/wx-biz-msg-crypt": "~0.0.2",
        "jpush/jpush": "^3.5",
        "elasticsearch/elasticsearch": "~5.0",
        "nategood/httpful": "*",
        "aferrandini/phpqrcode": "1.0.1",
        "shikuntian/aliyun-php-sdk-vod": "1.0.0",
        "php-amqplib/php-amqplib": "^2.12",
        "aws/aws-sdk-php": "^3.52",
        "phpoffice/phpspreadsheet": "^1.2",
        "phpmailer/phpmailer": "^6.0",
        "lcobucci/jwt": "^3.2",
        "mk-j/php_xlsxwriter": "~0.37.0",
        "cloudconvert/cloudconvert-php": "^2.2",
        "davidpersson/beanstalk": "^2.0",
        "baidu/aip-sdk": "^2.2",
        "phpseclib/phpseclib": "~2.0",
        "qcloud/cos-sdk-v5": "^2.1",
        "tencentcloud/tencentcloud-sdk-php": "^3.0",
        "alibabacloud/client": "^1.5",
        "php-ews/php-ews": "^1.0",
        "alibabacloud/dysmsapi-20170525": "2.0.16",
        "alibabacloud/imagesearch-20201214": "4.0.0",
        "alibabacloud/nlsfiletrans": "^1.8",
        "smarty/smarty": "^3.1",
        "dompdf/dompdf": "^0.8.3",
        "smarty-gettext/smarty-gettext": "^1.7",
        "onelogin/php-saml": "^3.6.1",
        "pragmarx/google2fa": "v7.0.0",
        "alibabacloud/ice-20201109": "^1.3",
        "alibabacloud/vod-20170321": "^2.16",
        "alibabacloud/alinlp-20200629": "^2.0",
        "alibabacloud/sdk": "^1.8",
        "obs/esdk-obs-php": "^3.23",
        "alibabacloud/ocr-api-20210707": "^2.0",
        "alibabacloud/tingwu-20230930": "2.0.5",
        "volcengine/volcengine-php-sdk": "v1.0.24",
        "alibabacloud/speechfiletranscriberlite-20211221": "^7.0"
    },

    "suggest": {
        "ext-apcu": "*",
        "predis/predis": "Required to use the redis cache and queue drivers (~1.0)."
    },
    "apcu-autoloader": true,
    "autoload": {
        "psr-4": {
            "Key\\": "system/framework/Key",
            "App\\Common\\": "system/common",
            "App\\Transfers\\": "system/transfers",
            "imm\\": "system/aliyun-php-sdk-imm/imm",
            "Dm\\": "system/aliyun-php-sdk-dm/Dm",
            "Sms\\": "system/aliyun-php-sdk-sms/Sms",
            "NlsFileTrans\\": "system/aliyun-php-sdk-nls-filetrans",
            "NlsCloud\\": "system/aliyun-php-sdk-nls-cloud-meta",
            "setasign\\Fpdi\\": "system/setasign/fpdi/src"
        },
        "files": [
            "system/framework/Key/helpers.php",
            "system/aliyun-php-sdk-core/Config.php"
        ]
    },

    "scripts": {
        "post-root-package-install": [
            "php -r \"file_exists('.env') || copy('.env.sample', '.env');\""
        ],
        "post-install-cmd": [
            "php -r \"file_exists('.env') || copy('.env.sample', '.env');\""
        ]
    },

    "repositories": [
        {
            "type": "composer",
            "url": "https://mirrors.aliyun.com/composer/"
        }
    ]
}
